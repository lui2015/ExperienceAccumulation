# ===== Application =====
APP_ENV=dev
APP_DEBUG=true
# 主站对外 URL（用于 CORS / Cookie domain 等场景）
APP_BASE_URL=http://localhost:5173
# 应用挂载子路径（生产环境为 /experience，本地开发为空）
APP_ROOT_PATH=

# ===== Security =====
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# HTML 文件访问 Token 过期时间（分钟）
HTML_TOKEN_EXPIRE_MINUTES=5
# Cookie 是否仅 HTTPS（生产=true）
COOKIE_SECURE=false
# Cookie SameSite 策略（lax / strict / none）
COOKIE_SAMESITE=lax

# ===== Owner（首次启动时自动创建，仅生效一次）=====
OWNER_USERNAME=admin
OWNER_PASSWORD=please_change_me

# ===== Storage =====
# 数据目录（数据库 + 文件）
DATA_DIR=./data
STORAGE_DIR=./storage
BACKUP_DIR=./backups

# ===== Limits =====
MAX_HTML_SIZE_MB=20
MAX_COVER_SIZE_MB=5

# ===== HTML 沙箱 =====
# 生产为 https://view.luliming.xyz，本地开发可填 http://localhost:5174
HTML_VIEW_BASE_URL=http://localhost:5174
